{
    "name": "pi-scripts-bundle",
    "version": "1.0.0",
    "private": true,
    "description": "Unified package for Raspberry Pi utility scripts in temp/pi",
    "main": "camera_server.js",
    "scripts": {
        "start": "node camera_server.js",
        "camera": "node camera_server.js",
        "device:register": "node device_registration.js",
        "sensor:register": "node sensor_registration.js",
        "alert:single": "node rpi_send_single_alert_with_image.js",
        "alert:test": "node \"send_test_alert.js\""
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "express": "^4.18.2",
        "firebase-admin": "^13.7.0",
        "onoff": "^6.0.3",
        "wrtc": "^0.4.7"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
